# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (MongoDB Atlas)
# Get your connection string from: https://cloud.mongodb.com
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/jobboard?retryWrites=true&w=majority

# JWT Secret (generate a strong random string)
# You can generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_key_change_this_in_production

# Email Configuration (Optional - for notifications)
# If not configured, email notifications will be skipped gracefully
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
